   "source": [
    "import base64\n",
    "\n",
    "def encode_image(img_path, img_type=\"jpg\"):\n",
    "    with open(img_path, \"rb\") as f:\n",
    "        return f\"data:{img_type};base64,{base64.b64encode(f.read()).decode()}\""
   ],
